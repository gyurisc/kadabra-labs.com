---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Services',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Services"
    title="Technology solutions that drive real business results"
    subtitle="We do not just write code — we solve business problems. Every engagement starts with understanding your goals and ends with measurable outcomes."
    actions={[
      {
        variant: 'primary',
        target: '_blank',
        text: 'Book a Free Discovery Call',
        href: 'https://cal.com/kadabralabs/15min',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Our Services"
    subtitle="Each service is designed to deliver clear ROI for your business."
    columns={2}
    items={[
      {
        title: 'AI Integration & Automation',
        description:
          'Custom AI solutions integrated into your existing workflows. We build chatbots, document processors, recommendation engines, and intelligent automation using OpenAI, Claude, and open-source models. Typical project: €3,000–€15,000.',
        icon: 'tabler:robot',
      },
      {
        title: 'Web Application Development',
        description:
          'Full-stack web applications built with Next.js, React, and TypeScript. From MVPs to production systems — responsive, fast, and built to scale. Typical project: €5,000–€20,000.',
        icon: 'tabler:code',
      },
      {
        title: 'Workflow Automation',
        description:
          'Connect your tools and eliminate manual work. We use n8n, custom APIs, and integrations to automate repetitive processes — order handling, invoicing, data sync, notifications. Typical project: €1,500–€5,000.',
        icon: 'tabler:arrows-shuffle',
      },
      {
        title: 'Legacy System Modernization',
        description:
          'Modernize your .NET, WCF, or enterprise systems without starting from scratch. We refactor, re-platform, and add modern frontends to existing backends. Typical project: €5,000–€25,000.',
        icon: 'tabler:refresh',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    items={[
      {
        title: 'Fixed Pricing, No Surprises',
        description:
          'Every project gets a clear quote upfront. You know exactly what you pay before we start.',
        icon: 'tabler:currency-euro',
      },
      {
        title: 'Fast Delivery',
        description:
          'Most projects delivered in 2-6 weeks. We work iteratively so you see progress from week one.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Senior-Level Expertise',
        description:
          '15+ years building enterprise software for healthcare, finance, and SaaS. No juniors, no handoffs.',
        icon: 'tabler:award',
      },
      {
        title: 'AI-First Approach',
        description:
          'We use AI tools in our own workflow to deliver faster and smarter. We practice what we preach.',
        icon: 'tabler:brain',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Why choose Kadabra Labs?</h3>
    </Fragment>
  </Content>

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="What our clients say"
    testimonials={[]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        target: '_blank',
        text: 'Book a Discovery Call',
        href: 'https://cal.com/kadabralabs/15min',
        icon: 'tabler:phone',
      },
    ]}
    title="Let us talk about your project"
    subtitle="Book a free 15-minute discovery call. We will discuss your needs, suggest an approach, and give you a ballpark estimate — no strings attached."
  />
</Layout>
