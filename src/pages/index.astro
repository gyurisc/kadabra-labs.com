---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kadabra Labs — AI & Software Consulting',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Book a Call',
        href: 'https://cal.com/kadabralabs/15min',
        target: '_blank',
      },
      { text: 'Our Services', href: '#services' },
    ]}
  >
    <Fragment slot="title">AI that works for your business — not the other way around</Fragment>

    <Fragment slot="subtitle">
      We are a Budapest-based consultancy that helps companies automate workflows, build modern web apps, and
      integrate AI — with fixed pricing, fast delivery, and zero BS. Over 15 years of enterprise software experience.
    </Fragment>
  </Hero>

  <Note
    title="Why us?"
    description="Fixed pricing · Fast delivery · 15+ years experience · AI-first approach"
  />

  <!-- Features Widget *************** -->

  <Features
    id="services"
    tagline="Services"
    title="What we do"
    subtitle="From AI integration to full-stack development, we deliver solutions that work."
    items={[
      {
        title: 'AI Integration & Automation',
        description:
          'We integrate AI into your existing business processes. From chatbots to document processing, we make AI work for you.',
        icon: 'tabler:robot',
      },
      {
        title: 'Web Application Development',
        description:
          'Modern web applications built with Next.js, React, and TypeScript. Fast, scalable, and maintainable.',
        icon: 'tabler:code',
      },
      {
        title: 'Workflow Automation',
        description:
          'Automate repetitive tasks with n8n, custom APIs, and integrations. Save hours every week.',
        icon: 'tabler:arrows-shuffle',
      },
      {
        title: 'Legacy System Modernization',
        description:
          '.NET and enterprise system modernization. We bring your existing software into the modern era.',
        icon: 'tabler:refresh',
      },
    ]}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="How we work"
    items={[
      {
        title: 'Discovery Call',
        description:
          'We start with a free 15-minute call to understand your needs and see if we are a good fit.',
        icon: 'tabler:phone-call',
      },
      {
        title: 'Proposal & Plan',
        description:
          'We deliver a clear proposal with scope, timeline, and fixed pricing. No surprises.',
        icon: 'tabler:file-description',
      },
      {
        title: 'Build & Deliver',
        description:
          'We build iteratively, keeping you in the loop. You see progress every week.',
        icon: 'tabler:tools',
      },
      {
        title: 'Ready!',
        icon: 'tabler:check',
      },
    ]}
  />

  <!-- HighlightedPosts Widget ******* -->

  <BlogLatestPosts
    title="Latest from our blog"
    information="Insights on AI, web development, and building software products."
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Frequently Asked Questions"
    subtitle=""
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'What technologies do you work with?',
        description:
          '.NET, C#, React, Next.js, TypeScript, Python, Node.js, SQLite, PostgreSQL, MongoDB, Redis, Docker, Azure, and n8n for workflow automation.',
      },
      {
        title: 'How much does a typical project cost?',
        description:
          'Projects typically range from €2,000 to €20,000 depending on scope. We always provide a fixed-price quote upfront after our discovery call.',
      },
      {
        title: 'Do you work with international clients?',
        description:
          'Yes! We are based in Budapest, Hungary but work with clients across Europe and beyond. All communication is in English.',
      },
      {
        title: 'What is your availability?',
        description:
          'We are typically available within 1-2 weeks. Book a free 15-minute call to discuss your project timeline.',
      },
    ]}
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Years Experience', amount: '15+' },
      { title: 'Projects Delivered', amount: '50+' },
      { title: 'Happy Clients', amount: '10+' },
      { title: 'Average Rating', amount: '4.9' },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Book a Call',
        href: 'https://cal.com/kadabralabs/15min',
        target: '_blank',
        icon: 'tabler:phone',
      },
    ]}
  >
    <Fragment slot="title">Ready to get started?</Fragment>

    <Fragment slot="subtitle">
      Book a free 15-minute discovery call. No commitment, no pressure — just a conversation about your project.
    </Fragment>
  </CallToAction>
</Layout>
